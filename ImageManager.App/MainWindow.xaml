<Window x:Class="ImageManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ImageManager.App.ViewModels"
        mc:Ignorable="d"
        Title="ImageManager"
        MinWidth="1400"
        MinHeight="900"
        Width="1920"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        Foreground="#FFF0F0F0">
    <Window.Resources>
        <SolidColorBrush x:Key="BgWindow" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="BgPanel" Color="#FF252526" />
        <SolidColorBrush x:Key="BgInput" Color="#FF2D2D30" />
        <SolidColorBrush x:Key="BgHover" Color="#FF3E3E42" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#FF3E3E42" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFF0F0F0" />
        <SolidColorBrush x:Key="TextMuted" Color="#FFCCCCCC" />

        <Style TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="Control">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="SelectionBrush" Value="#FF264F78" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgHover}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="6,3" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgHover}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF264F78" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0"
                                Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BgPanel}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BgHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgInput}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:FileTreeNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <CheckBox IsThreeState="True" IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" />
                <TextBlock Margin="6,0,0,0"
                           Foreground="{StaticResource TextBrush}"
                           Text="{Binding Name}"
                           MouseLeftButtonDown="FileTreeNodeName_OnMouseLeftButtonDown">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                    <Setter Property="Cursor" Value="Hand" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </HierarchicalDataTemplate>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgPanel}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource BgPanel}" />
            <Setter Property="AlternatingRowBackground" Value="#FF2B2B2E" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
            <DockPanel LastChildFill="True">
                <TextBox Text="{Binding StatusText}"
                         VerticalAlignment="Center"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Margin="6,0,0,0" Padding="10,4" Content="Load Config" Command="{Binding LoadConfigCommand}" />
                    <Button Margin="6,0,0,0" Padding="10,4" Content="Save Config" Command="{Binding SaveConfigCommand}" />
                    <Button Margin="6,0,0,0" Padding="10,4" Content="Scan Tracking" Command="{Binding RunScanCommand}" />
                    <Button Margin="6,0,0,0" Padding="10,4" Content="Backup" Command="{Binding RunBackupCommand}" />
                    <Button Margin="6,0,0,0" Padding="10,4" Content="Purge Staging" Command="{Binding PurgeStageCommand}" />
                    <Button Margin="6,0,0,0" Padding="10,4" Content="Load Counts" Command="{Binding LoadCountsCommand}" />
                    <Button Margin="6,0,0,0" Padding="10,4" Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Text="Tracked File Tree (Main-rooted)" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Margin="6,0,0,0" Padding="8,2" Content="Expand all" Command="{Binding ExpandAllFileTreeCommand}" />
                        <Button Margin="6,0,0,0" Padding="8,2" Content="Collapse all" Command="{Binding CollapseAllFileTreeCommand}" />
                        <Button Margin="6,0,0,0" Padding="10,2" Content="Apply Selection" Command="{Binding ApplyTreeSelectionCommand}" />
                    </StackPanel>
                </Grid>
                <TreeView Grid.Row="2" ItemsSource="{Binding FileTreeView.Roots}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
            <TabControl>
                <TabItem Header="Configuration">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Folder Paths" />
                                <TextBlock Margin="0,8,0,2" Text="Main Roots (multiple; separated by ; )" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding MainRootsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             Height="50"
                                             VerticalScrollBarVisibility="Auto" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Add root…" Command="{Binding BrowseAddMainRootCommand}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,2" Text="Main Root" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Config.MainRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Browse…" Command="{Binding BrowseMainRootCommand}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,2" Text="Stage Root" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Config.StageRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Browse…" Command="{Binding BrowseStageRootCommand}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,2" Text="Backup Root (small)" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Config.BackupRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Browse…" Command="{Binding BrowseBackupRootCommand}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,2" Text="Full Backup Root" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Config.FullBackupRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Browse…" Command="{Binding BrowseFullBackupRootCommand}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,2" Text="Archive Root" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Config.ArchiveRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Browse…" Command="{Binding BrowseArchiveRootCommand}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,2" Text="Pre-APK Backup Root" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Config.PreApkCompressionBackupRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Browse…" Command="{Binding BrowsePreApkBackupRootCommand}" />
                                </Grid>

                                <Separator Margin="0,10,0,10" />
                                <TextBlock FontWeight="Bold" Text="Version and Budget" />
                                <TextBlock Margin="0,8,0,2" Text="Current Version ID" />
                                <TextBox Text="{Binding Config.CurrentVersionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,2" Text="Current Quality Tier" />
                                <TextBox Text="{Binding Config.CurrentQualityTier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,2" Text="APK Budget (bytes)" />
                                <TextBox Text="{Binding Config.ApkBudgetBytes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,2" Text="WebP Encoder Executable (e.g. nconvert.exe)" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Config.WebpEncoderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2" Margin="0" Padding="10,2" Content="Browse…" Command="{Binding BrowseEncoderPathCommand}" />
                                </Grid>
                                <TextBlock Margin="0,8,0,2" Text="Default lossy quality (0-100, used when no override matches)" />
                                <TextBox Text="{Binding Config.DefaultLossyQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,8,0,2" Text="APK minimum quality (lower bound for budget compression)" />
                                <TextBox Text="{Binding Config.ApkMinimumQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Separator Margin="0,10,0,10" />
                                <TextBlock FontWeight="Bold" Text="File extensions (controls indexing and workflows)" />
                                <TextBlock Margin="0,8,0,2" Text="Track extensions (indexed from Main)" />
                                <TextBox Text="{Binding TrackExtensionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="60"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Margin="0,8,0,2" Text="Archive extensions (used for Archive operations)" />
                                <TextBox Text="{Binding ArchiveExtensionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="60"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Margin="0,8,0,2" Text="Video extensions (used for 'videos only' flows and counts)" />
                                <TextBox Text="{Binding VideoExtensionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="40"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Margin="0,8,0,2" Text="Finished extensions (used for 'Return Finished from Stage')" />
                                <TextBox Text="{Binding FinishedExtensionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="40"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Margin="0,8,0,2" Text="Compression input extensions (image types allowed for Stage → WebP)" />
                                <TextBox Text="{Binding CompressionInputExtensionsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="50"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Margin="0,8,0,2" Text="Discrepancy map extension source -> target (Backup png -> Main webp check)" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding DiscrepancyMapSourceExtensionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="2" Text="{Binding DiscrepancyMapTargetExtensionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Content="Apply Extensions" Padding="12,4" Command="{Binding ApplyExtensionsCommand}" />
                                    <TextBlock Margin="10,6,0,0" Opacity="0.8"
                                               Text="Separate with ; or comma. Use .png or png — both work." />
                                </WrapPanel>

                                <Separator Margin="0,10,0,10" />
                                <TextBlock FontWeight="Bold" Text="Conflict handling and conversion rules" />
                                <TextBlock Margin="0,8,0,2" Text="Default conflict action" />
                                <ComboBox ItemsSource="{Binding ConflictActions}"
                                          SelectedItem="{Binding Config.ConflictPolicy.DefaultAction, Mode=TwoWay}" />
                                <CheckBox Margin="0,8,0,0"
                                          Content="Only existing targets (do not create missing files during restore/copy)"
                                          IsChecked="{Binding Config.ConflictPolicy.OnlyExistingTargets, Mode=TwoWay}" />
                                <TextBlock Margin="0,8,0,2" Text="Extension overrides (.webm=Skip; .png=Overwrite)" />
                                <TextBox Text="{Binding ConflictOverrideText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="50"
                                         VerticalScrollBarVisibility="Auto" />
                                <TextBlock Margin="0,8,0,2" Text="Per-folder conversion overrides (events=lossless; background=90)" />
                                <TextBox Text="{Binding ConversionOverridesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="50"
                                         VerticalScrollBarVisibility="Auto" />
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Content="Apply Rules" Padding="12,4" Command="{Binding ApplyRulesCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                        <Border Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="What this tab does" />
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="This tab defines all roots, extension filters, and behavior rules used by every workflow." />
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap">
                                    <Run FontWeight="Bold" Text="Buttons in this tab:" />
                                    <LineBreak />
                                    <Run Text="• Add root… / Browse… (all path rows): open folder/file dialogs and write the selected path into the corresponding field." />
                                    <LineBreak />
                                    <Run Text="• Apply Extensions: parses Track/Archive/Video/Finished/Compression-input extensions and discrepancy map source/target into config." />
                                    <LineBreak />
                                    <Run Text="• Apply Rules: parses conflict overrides and per-folder conversion overrides (e.g. events=lossless)." />
                                    <LineBreak />
                                    <Run Text="Related global buttons (top bar): Load Config reads saved settings, Save Config writes current settings to config.json." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Track">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <Button Content="Scan and Index Tracking" Padding="12,6" HorizontalAlignment="Left" Command="{Binding RunScanCommand}" />
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"
                                       Text="Updates tracking from Main using configured extensions. The tree on the left refreshes after scan." />
                        </StackPanel>
                        <Border Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="Track Help" />
                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap">
                                    <Run FontWeight="Bold" Text="Scan and Index Tracking" />
                                    <LineBreak />
                                    <Run Text="Scans all configured main roots using Track extensions, updates the tracking database, and refreshes the left main tree selection model used by backup/staging/archive workflows." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Backup">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <WrapPanel>
                                <Button Content="Run Full + Small Backup" Margin="0,0,8,8" Padding="12,6" Command="{Binding RunBackupCommand}" />
                                <Button Content="Run Current-Version Backup" Margin="0,0,8,8" Padding="12,6" Command="{Binding RunCurrentVersionBackupCommand}" />
                                <Button Content="Return All from Backup" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnAllFromBackupCommand}" />
                                <Button Content="Return Videos from Backup" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnVideosFromBackupCommand}" />
                                <Button Content="Return WebP from Backup" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnWebpFromBackupCommand}" />
                                <Button Content="Refresh Backup Views" Margin="0,0,8,8" Padding="12,6" Command="{Binding RefreshBackupTreesCommand}" />
                            </WrapPanel>
                        </StackPanel>
                        <!-- Small backup | Full backup | Help — side by side -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="320" MinWidth="220" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Small Backup Folder View" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Margin="6,0,0,0" Padding="8,2" Content="Expand all" Command="{Binding ExpandAllBackupTreeCommand}" />
                                            <Button Margin="6,0,0,0" Padding="8,2" Content="Collapse all" Command="{Binding CollapseAllBackupTreeCommand}" />
                                        </StackPanel>
                                    </Grid>
                                    <TreeView Grid.Row="2" ItemsSource="{Binding BackupTreeView.Roots}" />
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Full Backup Folder View" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Margin="6,0,0,0" Padding="8,2" Content="Expand all" Command="{Binding ExpandAllFullBackupTreeCommand}" />
                                            <Button Margin="6,0,0,0" Padding="8,2" Content="Collapse all" Command="{Binding CollapseAllFullBackupTreeCommand}" />
                                        </StackPanel>
                                    </Grid>
                                    <TreeView Grid.Row="2" ItemsSource="{Binding FullBackupTreeView.Roots}" />
                                </Grid>
                            </Border>
                            <Border Grid.Column="4" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Text="Backup Help (button-by-button)" />
                                        <LineBreak />
                                        <Run Text="• Run Full + Small Backup: copies selected tracked files to both Backup Root and Full Backup Root." />
                                        <LineBreak />
                                        <Run Text="• Run Current-Version Backup: same as above, but only files whose tracked VersionId equals Current Version ID." />
                                        <LineBreak />
                                        <Run Text="• Return All from Backup: restores all files from small backup to main roots (subject to conflict policy)." />
                                        <LineBreak />
                                        <Run Text="• Return Videos from Backup: restores only extensions listed in Video extensions." />
                                        <LineBreak />
                                        <Run Text="• Return WebP from Backup: restores only .webp files from small backup." />
                                        <LineBreak />
                                        <Run Text="• Refresh Backup Views: reloads the small/full backup folder trees shown in this tab." />
                                    </TextBlock>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Staging">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <WrapPanel>
                                <Button Content="Stage (Move)" Margin="0,0,8,8" Padding="12,6" Command="{Binding StageMoveCommand}" />
                                <Button Content="Stage (Copy)" Margin="0,0,8,8" Padding="12,6" Command="{Binding StageCopyCommand}" />
                                <Button Content="Copy Backup to Stage" Margin="0,0,8,8" Padding="12,6" Command="{Binding CopyBackupToStageCommand}" />
                                <Button Content="Return All from Stage" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnAllFromStageCommand}" />
                                <Button Content="Return Videos from Stage" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnVideosFromStageCommand}" />
                                <Button Content="Return Finished from Stage" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnFinishedFromStageCommand}" />
                                <Button Content="Purge Staging Folder" Margin="0,0,8,8" Padding="12,6" Command="{Binding PurgeStageCommand}" />
                                <Button Content="Refresh Stage View" Margin="0,0,8,8" Padding="12,6" Command="{Binding RefreshStageTreeCommand}" />
                            </WrapPanel>
                        </StackPanel>
                        <!-- Stage tree | Help — side by side -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="320" MinWidth="220" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Stage Folder View" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Margin="6,0,0,0" Padding="8,2" Content="Expand all" Command="{Binding ExpandAllStageTreeCommand}" />
                                            <Button Margin="6,0,0,0" Padding="8,2" Content="Collapse all" Command="{Binding CollapseAllStageTreeCommand}" />
                                        </StackPanel>
                                    </Grid>
                                    <TreeView Grid.Row="2" ItemsSource="{Binding StageTreeView.Roots}" />
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Text="Staging Help (button-by-button)" />
                                        <LineBreak />
                                        <Run Text="• Stage (Move): moves currently selected tracked files from main roots into stage." />
                                        <LineBreak />
                                        <Run Text="• Stage (Copy): copies selected tracked files into stage (originals remain in main)." />
                                        <LineBreak />
                                        <Run Text="• Copy Backup to Stage: copies everything from small backup into stage." />
                                        <LineBreak />
                                        <Run Text="• Return All from Stage: copies all stage files back to mapped main-root targets." />
                                        <LineBreak />
                                        <Run Text="• Return Videos from Stage: returns only extensions listed in Video extensions." />
                                        <LineBreak />
                                        <Run Text="• Return Finished from Stage: returns only extensions listed in Finished extensions (e.g. .webp/.webm)." />
                                        <LineBreak />
                                        <Run Text="• Purge Staging Folder: deletes files and folders inside stage root." />
                                        <LineBreak />
                                        <Run Text="• Refresh Stage View: reloads the stage folder tree in this tab." />
                                    </TextBlock>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Archive">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <WrapPanel>
                                <Button Content="Backup to Archive (Version/Quality)" Margin="0,0,8,8" Padding="12,6" Command="{Binding ArchiveBackupCommand}" />
                                <Button Content="Copy Archive to Stage" Margin="0,0,8,8" Padding="12,6" Command="{Binding ArchiveToStageCommand}" />
                                <Button Content="Copy Archive to Main" Margin="0,0,8,8" Padding="12,6" Command="{Binding ArchiveToMainCommand}" />
                                <Button Content="Return All from Archive" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnAllFromArchiveCommand}" />
                                <Button Content="Return Videos from Archive" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnVideosFromArchiveCommand}" />
                                <Button Content="Return WebP from Archive" Margin="0,0,8,8" Padding="12,6" Command="{Binding ReturnWebpFromArchiveCommand}" />
                            </WrapPanel>
                        </StackPanel>
                        <Border Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="Bold" Text="Archive Help (button-by-button)" />
                                <LineBreak />
                                <Run Text="• Backup to Archive (Version/Quality): copies selected tracked files into ArchiveRoot/CurrentVersionId/CurrentQualityTier." />
                                <LineBreak />
                                <Run Text="• Copy Archive to Stage: copies from current archive bucket into stage root." />
                                <LineBreak />
                                <Run Text="• Copy Archive to Main: copies all files from current archive bucket into mapped main roots." />
                                <LineBreak />
                                <Run Text="• Return All from Archive: same as Copy Archive to Main for the current bucket." />
                                <LineBreak />
                                <Run Text="• Return Videos from Archive: returns only configured video extensions from current archive bucket." />
                                <LineBreak />
                                <Run Text="• Return WebP from Archive: returns only .webp files from current archive bucket." />
                            </TextBlock>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Compression">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <WrapPanel>
                                <Button Content="Compress Stage to WebP" Margin="0,0,8,8" Padding="12,6" Command="{Binding CompressStageCommand}" />
                                <Button Content="Prepare Main for APK Budget" Margin="0,0,8,8" Padding="12,6" Command="{Binding CompressMainBudgetCommand}" />
                                <Button Content="Refresh Stage Tree" Margin="0,0,8,8" Padding="12,6" Command="{Binding RefreshStageTreeCommand}" />
                            </WrapPanel>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="Bold" Text="Compression Log (live)" />
                                        <TextBox x:Name="CompressionLogBox"
                                                 Grid.Row="2"
                                                 Text="{Binding CompressionDetails}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto" />
                                    </Grid>
                                </Border>
                                <Border Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="6" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Stage File Tree (live snapshot)" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Margin="6,0,0,0" Padding="8,2" Content="Expand all" Command="{Binding ExpandAllStageTreeCommand}" />
                                                <Button Margin="6,0,0,0" Padding="8,2" Content="Collapse all" Command="{Binding CollapseAllStageTreeCommand}" />
                                            </StackPanel>
                                        </Grid>
                                        <TreeView Grid.Row="2" ItemsSource="{Binding StageTreeView.Roots}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                        <Border Grid.Column="2" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="Bold" Text="Compression Help (button-by-button)" />
                                <LineBreak />
                                <Run Text="• Compress Stage to WebP: converts stage files matching Track + Compression-input extensions to .webp, applies conversion overrides, logs progress/ETA/savings, and writes failure logs." />
                                <LineBreak />
                                <Run Text="• Prepare Main for APK Budget: backs up main .webp files to Pre-APK backup root, then recompresses until APK budget target is reached or minimum quality is hit." />
                                <LineBreak />
                                <Run Text="• Refresh Stage Tree: reloads the stage snapshot tree shown next to the live compression log." />
                            </TextBlock>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Audit">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Column="0">
                            <Button Margin="0,0,8,8" Content="Main vs Backup" Padding="12,6" Command="{Binding RunDiscrepancyCheckCommand}" />
                            <Button Margin="0,0,8,8" Content="Main vs Full Backup" Padding="12,6" Command="{Binding RunDiscrepancyFullBackupCommand}" />
                            <Button Margin="0,0,8,8" Content="Main vs Archive (Current)" Padding="12,6" Command="{Binding RunDiscrepancyArchiveCommand}" />
                            <Button Margin="0,0,8,8" Content="Backup png -> Main webp" Padding="12,6" Command="{Binding RunDiscrepancyBackupToMainMappedCommand}" />
                        </WrapPanel>
                        <DataGrid Grid.Row="2" Grid.Column="0"
                                  AutoGenerateColumns="False"
                                  ItemsSource="{Binding Discrepancies}"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Relative Path" Binding="{Binding RelativePath}" Width="2*" />
                                <DataGridTextColumn Header="Issue" Binding="{Binding Issue}" Width="*" />
                                <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedLocation}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Column="2" Grid.RowSpan="3" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="Bold" Text="Audit Help (button-by-button)" />
                                <LineBreak />
                                <Run Text="• Main vs Backup: reports files present in each main root but missing in small backup." />
                                <LineBreak />
                                <Run Text="• Main vs Full Backup: reports files present in main roots but missing in full backup." />
                                <LineBreak />
                                <Run Text="• Main vs Archive (Current): checks current archive bucket (version/quality) against main roots." />
                                <LineBreak />
                                <Run Text="• Backup png -> Main webp: mapped extension check using configurable source/target discrepancy extensions." />
                                <LineBreak />
                                <Run Text="Results grid columns: Relative Path (file), Issue (missing/type), Expected (where counterpart should exist)." />
                            </TextBlock>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="4" Grid.ColumnSpan="3" Padding="8" BorderThickness="1" CornerRadius="6" BorderBrush="#FF3E3E3E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock FontWeight="Bold" FontSize="14" Text="Global Counts" />
                <DataGrid Grid.Row="2"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding Counts}"
                          IsReadOnly="True"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Location" Binding="{Binding LocationName}" Width="2*" />
                        <DataGridTextColumn Header="Images" Binding="{Binding ImageCount}" Width="*" />
                        <DataGridTextColumn Header="Videos" Binding="{Binding VideoCount}" Width="*" />
                        <DataGridTextColumn Header="Total Bytes" Binding="{Binding TotalBytes}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
